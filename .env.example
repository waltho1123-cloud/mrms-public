# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mrms?schema=public"

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# OpenAI API Key (for STT transcription)
OPENAI_API_KEY="sk-..."

# Anthropic API Key (for AI summarization)
ANTHROPIC_API_KEY="sk-ant-..."

# JWT Secret for admin authentication
# IMPORTANT: Change this in production!
NEXTAUTH_SECRET="your-secret-key-here"
# JWT_SECRET="alternative-env-var-name"

# File upload settings
UPLOAD_DIR="/tmp/mrms-uploads"
MAX_FILE_SIZE_MB="200"

# Auto-push to LINE after summarization (true/false)
AUTO_PUSH="false"

# Admin seed credentials (used by prisma/seed.ts)
ADMIN_EMAIL="admin@mrms.local"
ADMIN_PASSWORD="changeme123"
